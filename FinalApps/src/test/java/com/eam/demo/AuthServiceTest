package com.eam.demo;

import com.eam.demo.dto.AuthRequest;
import com.eam.demo.dto.AuthResponse;
import com.eam.demo.dto.OrganizationResponse;
import com.eam.demo.dto.RegisterOrganizationRequest;
import com.eam.demo.entity.Organization;
import com.eam.demo.entity.Role;
import com.eam.demo.entity.UserAccount;
import com.eam.demo.exception.BadRequestException;
import com.eam.demo.repository.OrganizationRepository;
import com.eam.demo.repository.UserAccountRepository;
import com.eam.demo.security.CustomUserDetails;
import com.eam.demo.security.JwtService;
import com.eam.demo.service.AuthService;
import com.eam.demo.service.TenantContextService;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.security.authentication.AuthenticationManager;
import org.springframework.security.authentication.BadCredentialsException;
import org.springframework.security.authentication.UsernamePasswordAuthenticationToken;
import org.springframework.security.crypto.password.PasswordEncoder;

import java.util.Optional;

import static org.assertj.core.api.Assertions.*;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
@DisplayName("AuthService - Pruebas Unitarias")
class AuthServiceTest {

    @Mock private OrganizationRepository organizationRepository;
    @Mock private UserAccountRepository userAccountRepository;
    @Mock private PasswordEncoder passwordEncoder;
    @Mock private AuthenticationManager authenticationManager;
    @Mock private JwtService jwtService;
    @Mock private TenantContextService tenantContextService;

    @InjectMocks
    private AuthService authService;

    private RegisterOrganizationRequest validRegisterRequest;
    private AuthRequest validAuthRequest;
    private Organization savedOrg;
    private UserAccount activeUser;

    @BeforeEach
    void setUp() {
        validRegisterRequest = new RegisterOrganizationRequest();
        validRegisterRequest.setOrganizationName("Empresa Demo");
        validRegisterRequest.setOrganizationCode("EMP01");
        validRegisterRequest.setAdminName("Admin Demo");
        validRegisterRequest.setAdminEmail("admin@demo.com");
        validRegisterRequest.setAdminPassword("Password123!");

        validAuthRequest = new AuthRequest();
        validAuthRequest.setEmail("admin@demo.com");
        validAuthRequest.setPassword("Password123!");

        savedOrg = new Organization();
        savedOrg.setId(1L);
        savedOrg.setName("Empresa Demo");
        savedOrg.setCode("EMP01");
        savedOrg.setActive(true);

        activeUser = new UserAccount();
        activeUser.setId(1L);
        activeUser.setFullName("Admin Demo");
        activeUser.setEmail("admin@demo.com");
        activeUser.setPassword("$2a$hash");
        activeUser.setRole(Role.ADMIN);
        activeUser.setActive(true);
        activeUser.setOrganization(savedOrg);
    }

    @Test
    @DisplayName("REGISTER - Solicitud válida debe crear organización y admin, retornar OrganizationResponse")
    void registerOrganization_ValidRequest_ShouldReturnOrganizationResponse() {
        when(organizationRepository.existsByNameIgnoreCase("Empresa Demo")).thenReturn(false);
        when(organizationRepository.existsByCodeIgnoreCase("EMP01")).thenReturn(false);
        when(userAccountRepository.existsByEmailIgnoreCase("admin@demo.com")).thenReturn(false);
        when(organizationRepository.save(any(Organization.class))).thenReturn(savedOrg);
        when(passwordEncoder.encode("Password123!")).thenReturn("$2a$hash");
        when(userAccountRepository.save(any(UserAccount.class))).thenReturn(activeUser);

        OrganizationResponse result = authService.registerOrganization(validRegisterRequest);

        assertThat(result).isNotNull();
        assertThat(result.getId()).isEqualTo(1L);
        assertThat(result.getName()).isEqualTo("Empresa Demo");
        assertThat(result.getCode()).isEqualTo("EMP01");
        assertThat(result.isActive()).isTrue();

        verify(organizationRepository, times(1)).save(any(Organization.class));
        verify(userAccountRepository, times(1)).save(any(UserAccount.class));
        verify(passwordEncoder, times(1)).encode("Password123!");
    }

    @Test
    @DisplayName("REGISTER - Nombre duplicado debe lanzar BadRequestException")
    void registerOrganization_DuplicateName_ShouldThrowBadRequestException() {
        when(organizationRepository.existsByNameIgnoreCase("Empresa Demo")).thenReturn(true);

        assertThatThrownBy(() -> authService.registerOrganization(validRegisterRequest))
                .isInstanceOf(BadRequestException.class)
                .hasMessageContaining("organizacion con ese nombre");

        verify(organizationRepository, never()).save(any());
        verify(userAccountRepository, never()).save(any());
    }

    @Test
    @DisplayName("REGISTER - Código duplicado debe lanzar BadRequestException")
    void registerOrganization_DuplicateCode_ShouldThrowBadRequestException() {
        when(organizationRepository.existsByNameIgnoreCase("Empresa Demo")).thenReturn(false);
        when(organizationRepository.existsByCodeIgnoreCase("EMP01")).thenReturn(true);

        assertThatThrownBy(() -> authService.registerOrganization(validRegisterRequest))
                .isInstanceOf(BadRequestException.class)
                .hasMessageContaining("organizacion con ese codigo");

        verify(organizationRepository, never()).save(any());
    }

    @Test
    @DisplayName("REGISTER - Email de admin duplicado debe lanzar BadRequestException")
    void registerOrganization_DuplicateAdminEmail_ShouldThrowBadRequestException() {
        when(organizationRepository.existsByNameIgnoreCase("Empresa Demo")).thenReturn(false);
        when(organizationRepository.existsByCodeIgnoreCase("EMP01")).thenReturn(false);
        when(userAccountRepository.existsByEmailIgnoreCase("admin@demo.com")).thenReturn(true);

        assertThatThrownBy(() -> authService.registerOrganization(validRegisterRequest))
                .isInstanceOf(BadRequestException.class)
                .hasMessageContaining("usuario con ese email");

        verify(organizationRepository, never()).save(any());
    }

    @Test
    @DisplayName("LOGIN - Credenciales válidas deben retornar AuthResponse con token JWT")
    void login_ValidCredentials_ShouldReturnAuthResponseWithToken() {
        when(authenticationManager.authenticate(any(UsernamePasswordAuthenticationToken.class))).thenReturn(null);
        when(userAccountRepository.findByEmailIgnoreCase("admin@demo.com")).thenReturn(Optional.of(activeUser));
        when(jwtService.generateToken(any(CustomUserDetails.class))).thenReturn("eyJhbGciOiJIUzI1NiJ9.test.token");

        AuthResponse result = authService.login(validAuthRequest);

        assertThat(result).isNotNull();
        assertThat(result.getToken()).isEqualTo("eyJhbGciOiJIUzI1NiJ9.test.token");
        assertThat(result.getTokenType()).isEqualTo("Bearer");
        assertThat(result.getEmail()).isEqualTo("admin@demo.com");
        assertThat(result.getRole()).isEqualTo(Role.ADMIN);
        assertThat(result.getOrganizationId()).isEqualTo(1L);

        verify(jwtService, times(1)).generateToken(any(CustomUserDetails.class));
    }

    @Test
    @DisplayName("LOGIN - Credenciales incorrectas deben propagar excepción de autenticación")
    void login_InvalidCredentials_ShouldThrowException() {
        when(authenticationManager.authenticate(any(UsernamePasswordAuthenticationToken.class)))
                .thenThrow(new BadCredentialsException("Credenciales invalidas"));

        assertThatThrownBy(() -> authService.login(validAuthRequest))
                .isInstanceOf(BadCredentialsException.class);

        verify(jwtService, never()).generateToken(any());
    }

    @Test
    @DisplayName("LOGIN - Usuario inactivo debe lanzar BadRequestException")
    void login_InactiveUser_ShouldThrowBadRequestException() {
        activeUser.setActive(false);
        when(authenticationManager.authenticate(any())).thenReturn(null);
        when(userAccountRepository.findByEmailIgnoreCase("admin@demo.com")).thenReturn(Optional.of(activeUser));

        assertThatThrownBy(() -> authService.login(validAuthRequest))
                .isInstanceOf(BadRequestException.class)
                .hasMessageContaining("inactivo");

        verify(jwtService, never()).generateToken(any());
    }

    @Test
    @DisplayName("CURRENT ORG - Usuario autenticado debe retornar su organización")
    void currentOrganization_AuthenticatedUser_ShouldReturnOrganization() {
        when(tenantContextService.currentOrganization()).thenReturn(savedOrg);

        OrganizationResponse result = authService.currentOrganization();

        assertThat(result).isNotNull();
        assertThat(result.getId()).isEqualTo(1L);
        assertThat(result.getName()).isEqualTo("Empresa Demo");
        assertThat(result.getCode()).isEqualTo("EMP01");

        verify(tenantContextService, times(1)).currentOrganization();
    }
}